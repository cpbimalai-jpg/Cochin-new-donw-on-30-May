{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/properties",
      "destination": "/api/properties"
    },
    {
      "source": "/api/research-news",
      "destination": "/api/research-news"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
